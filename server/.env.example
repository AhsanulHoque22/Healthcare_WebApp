# ============================================================
# ENVIRONMENT CONFIGURATION — COPY TO .env AND FILL IN VALUES
# ============================================================
# Run: cp server/.env.example server/.env
# Then fill in every value before starting the server.
# NEVER commit .env to git.
# ============================================================

NODE_ENV=development
PORT=5001

# ============================================================
# DATABASE CONFIGURATION (Supabase / PostgreSQL)
# ============================================================
DB_HOST=your-supabase-pooler-host.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-db-password
DB_DIALECT=postgres
DB_SSL=true

# ============================================================
# JWT CONFIGURATION
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_EXPIRE=7d

# ============================================================
# CLIENT CONFIGURATION
# ============================================================
CLIENT_URL=http://localhost:3000

# ============================================================
# EMAIL CONFIGURATION (Brevo / SMTP)
# ============================================================
BREVO_API_KEY=your-brevo-api-key
FROM_EMAIL=your-email@example.com
FROM_NAME=Livora Healthcare
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password

# ============================================================
# FILE UPLOAD CONFIGURATION
# ============================================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# CLOUDINARY CONFIGURATION
# Get your credentials from: https://cloudinary.com/console
# ============================================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================================
# AI SERVICE CONFIGURATION
# ============================================================
# Groq — chatbot reasoning and document extraction
# Get your key from: https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# Deepgram — voice-to-text transcription
# Get your key from: https://console.deepgram.com
DEEPGRAM_API_KEY=your-deepgram-api-key

# Gemini — legacy fallback (optional)
# Get your key from: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key

# ============================================================
# REDIS (required for rate limiting in multi-instance deploys)
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# LANGFUSE OBSERVABILITY (Optional — traces every LLM call)
# Provides latency, cost, token usage, and safety audit dashboards.
# Leave blank to disable — the app runs normally without it.
# Get your keys from: https://cloud.langfuse.com (free tier available)
# ============================================================
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
